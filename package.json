{
  "name": "resume-cicd",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A LaTeX resume compiled in CI and served as a git-tracked, view-counted PDF on Vercel.",
  "scripts": {
    "build:pdf": "latexmk -pdf -interaction=nonstopmode resume.tex && node -e \"require('fs').mkdirSync('assets',{recursive:true});require('fs').copyFileSync('resume.pdf','assets/resume.pdf')\"",
    "dev": "vercel dev"
  },
  "dependencies": {
    "@upstash/redis": "^1.34.0"
  }
}
