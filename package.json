{
  "name": "whoami",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A LaTeX resume compiled in CI and served as a git-tracked, view-counted PDF on Vercel.",
  "scripts": {
    "resume": "node scripts/cli.mjs",
    "tailor": "node scripts/cli.mjs tailor",
    "sync": "node scripts/cli.mjs sync",
    "status": "node scripts/cli.mjs status",
    "build:pdf": "node scripts/build-pdf.mjs",
    "build:pdf:docker": "node scripts/build-pdf.mjs",
    "verify": "node scripts/build-pdf.mjs && node scripts/check-resume.js",
    "check": "node scripts/check-resume.js",
    "check:source": "node scripts/check-resume.js --source",
    "check:pdf": "node scripts/check-resume.js --pdf",
    "check:width": "node scripts/check-resume.js --log",
    "dev": "vercel dev",
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath .githooks')}catch{}\""
  },
  "dependencies": {
    "@upstash/redis": "^1.34.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@clack/prompts": "^1.7.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "gradient-string": "^3.0.0",
    "log-symbols": "^7.0.1",
    "ora": "^9.4.1",
    "picocolors": "^1.1.1",
    "playwright": "^1.61.1",
    "unpdf": "^1.6.2"
  }
}
