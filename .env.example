# Copy to .env and fill in. .env is gitignored — never commit real keys.

# LLM provider — the tailor needs ONE of Gemini or DeepSeek (it has no offline
# mode). Set at least one key below. LLM_PROVIDER picks the default; if unset,
# whichever key is present is used (Gemini first). Override per-run with
# `--provider gemini|deepseek`.
LLM_PROVIDER=

# Google Gemini.
GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash).
GEMINI_MODEL=gemini-2.5-flash

# DeepSeek (OpenAI-compatible API).
DEEPSEEK_API_KEY=
# Optional model override (default: deepseek-chat).
DEEPSEEK_MODEL=deepseek-chat

# Chat agent (`resume chat`) — all optional. The agent loop reuses the keys above;
# these only steer which model drives the CONVERSATION and its memory embeddings.
# AGENT_PROVIDER: gemini | deepseek. Blank → same default as the tailor (LLM_PROVIDER,
# else whichever key is set). AGENT_MODEL blank → provider default (Gemini: gemini-2.5-pro,
# DeepSeek: deepseek-chat). Semantic recall needs a Gemini key (embeddings); a DeepSeek-only
# setup still chats, just without long-term recall.
AGENT_PROVIDER=
AGENT_MODEL=
AGENT_EMBEDDING_MODEL=text-embedding-004

# Gmail — optional. Needed only for `resume email` to actually SEND (drafting
# works without it). Use a Google APP PASSWORD, not your account password:
# Google Account → Security → 2-Step Verification (must be ON) → App passwords →
# generate one for "Mail". Paste the 16-char code (spaces are fine).
GMAIL_USER=
GMAIL_APP_PASSWORD=

# GitHub — optional. Public data scrapes without it, but a token raises the
# rate limit. Create a fine-grained/classic token with public read scope.
GITHUB_TOKEN=

# How long a scraped source stays "fresh" before the tailor re-scrapes (hours).
SCRAPE_TTL_HOURS=12

# LinkedIn — optional. To enable LIVE scraping, paste your `li_at` session
# cookie (DevTools > Application > Cookies > linkedin.com > li_at) and install
# Playwright (npm i -D playwright && npx playwright install chromium). Without
# it, the scraper falls back to parsing Linkedin_Profile.pdf in the repo root.
LINKEDIN_COOKIE=
