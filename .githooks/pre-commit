#!/bin/sh
# Validate the résumé's source structure before allowing a commit that touches
# resume.tex. Only the source check runs here — the PDF isn't rebuilt at commit
# time (CI does that). Bypass with `git commit --no-verify` if ever needed.
if git diff --cached --name-only | grep -q '^resume\.tex$'; then
  echo "Running résumé structure check (source)…"
  if ! pnpm --filter @resume/cli run check:source; then
    echo "✗ Commit blocked: resume.tex failed its structure check (see above)."
    exit 1
  fi
fi
